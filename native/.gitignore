# Capacitor / iOS shell — build artifacts only.
#
# The generated native/ios/ Xcode project IS committed (created once by the
# Phase-3 ios-bootstrap workflow). Only dependencies and build output are
# ignored — CocoaPods + the cordova-plugins bridge are regenerated in CI by
# `cap sync` + `pod install` before each build.

node_modules/

# CocoaPods + Capacitor-generated bridge (regenerated by `cap sync`).
ios/App/Pods/
ios/capacitor-cordova-ios-plugins/

# Xcode build output + per-user state.
ios/App/build/
ios/App/output/
ios/DerivedData/
build/
*.xcuserstate
xcuserdata/

# Generated app icons/splash (re-run `npm run assets` from native/assets/).
ios/App/App/Assets.xcassets/AppIcon.appiconset/AppIcon-*.png
ios/App/App/Assets.xcassets/Splash.imageset/

.DS_Store
