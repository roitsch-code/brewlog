<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.roitsch.btts</string>
	</array>
	<!-- Push — required for Live Activity push tokens (server pushes each brew
	     step so the activity advances while the phone is locked). TestFlight uses
	     the production APNs environment. -->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
