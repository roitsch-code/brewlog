# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ── User profile ──────────────────────────────────────────────────────────────
# Your name — used in AI system prompts to personalise responses
USER_DISPLAY_NAME=Your Name
# Your city/location — optional, used for context in the Explore chat
USER_LOCATION=Your City

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Postgres ──────────────────────────────────────────────────────────────────
# App → self-hosted Postgres on the same Hetzner VPS via docker-compose network.
# The hostname matches the service name in docker-compose.yml.
DATABASE_URL=postgres://brewlog:change-me@postgres:5432/brewlog

# ── Hetzner Object Storage (S3-compatible) ────────────────────────────────────
# Create a bucket in the Hetzner console (region nbg1 or fsn1), then generate
# an access key pair. Set the bucket to public-read for bag photos (not sensitive).
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_REGION=nbg1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=brewlog-photos
# Public URL prefix for uploaded photos — used to build the URL stored in Postgres.
NEXT_PUBLIC_S3_PUBLIC_URL_PREFIX=https://brewlog-photos.nbg1.your-objectstorage.com

# ── Session signing ───────────────────────────────────────────────────────────
# 32+ random bytes, base64 or hex — used by src/lib/auth/session.ts to sign JWTs.
AUTH_SECRET=

# ── Cron auth ─────────────────────────────────────────────────────────────────
# Ofelia (docker cron) sends this header to /api/research and /api/coffees/compact.
CRON_SECRET=your-cron-secret

# ── Webhook auth ──────────────────────────────────────────────────────────────
# Used to authenticate POST requests to /api/webhooks/coffee-alert
COFFEE_ALERT_WEBHOOK_SECRET=your-webhook-secret

# ── WebAuthn (Face ID / passkey) ──────────────────────────────────────────────
# Must match the domain the app is served from. Keep these stable across the
# Firebase → Hetzner migration so existing passkeys keep working.
WEBAUTHN_RP_ID=bettertastethansorry.com
WEBAUTHN_ORIGIN=https://bettertastethansorry.com

# ── PIN fallback ──────────────────────────────────────────────────────────────
# Used when WebAuthn fails or during domain moves. 5 attempts then 60s lockout.
AUTH_PIN=your-pin
