# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Firebase (client-side — safe to expose) ───────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firestore database ID ─────────────────────────────────────────────────────
# If using a custom database (not "(default)"), set its ID here
FIRESTORE_DATABASE_ID=your-database-id
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=your-database-id

# ── Firebase Admin SDK (server-side only — keep secret) ───────────────────────
# Paste the full service account JSON as a single line (minified)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Cron auth ─────────────────────────────────────────────────────────────────
# Used to authenticate Vercel cron calls to /api/research
# IMPORTANT: set via: printf "your-secret" | vercel env add CRON_SECRET production
CRON_SECRET=your-cron-secret

# ── Webhook auth ──────────────────────────────────────────────────────────────
# Used to authenticate POST requests to /api/webhooks/coffee-alert
COFFEE_ALERT_WEBHOOK_SECRET=your-webhook-secret
