# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ── User profile ──────────────────────────────────────────────────────────────
# Your name — used in AI system prompts to personalise responses
USER_DISPLAY_NAME=Your Name
# Your city/location — optional, used for context in the Explore chat
USER_LOCATION=Your City

# ── Weather (daily greeting) ──────────────────────────────────────────────────
# Coordinates for the daily home greeting's optional weather angle
# (Open-Meteo, free, no API key). A hot day steers the suggestion toward
# iced coffee; on an ordinary day weather is ignored. Defaults to
# Düsseldorf (51.2277, 6.7735) if unset — override with your coordinates.
WEATHER_LATITUDE=51.2277
WEATHER_LONGITUDE=6.7735

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Mistral (EU-hosted) — /recommend runs on Mistral Large when this is set ──────
# ≈¼ the Opus per-call cost (see issue #453). Leave empty to keep /recommend on
# Opus. RECOMMEND_PROVIDER overrides selection: "mistral" forces Mistral,
# "anthropic" forces Opus (instant rollback); empty = auto (Mistral if key present).
MISTRAL_API_KEY=
RECOMMEND_PROVIDER=

# ── Voice (Explore voice mode) ────────────────────────────────────────────────
# ElevenLabs handles both speech-to-text (Scribe) and spoken responses (TTS).
# One key, one vendor. Default voice id below is Rachel.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Override the API base URL when the key is on a regional residency stack:
#   EU:   https://api.eu.residency.elevenlabs.io
#   US:   https://api.us.residency.elevenlabs.io
# Leave unset for the default global stack (api.elevenlabs.io).
ELEVENLABS_BASE_URL=

# ── Postgres ──────────────────────────────────────────────────────────────────
# App → self-hosted Postgres on the same Hetzner VPS via docker-compose network.
# The hostname matches the service name in docker-compose.yml.
# POSTGRES_PASSWORD is used by the postgres container; DATABASE_URL must embed
# the same password so the app can connect.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://brewlog:change-me@postgres:5432/brewlog

# ── Hetzner Object Storage (S3-compatible) ────────────────────────────────────
# Create a bucket in the Hetzner console (region nbg1 or fsn1), then generate
# an access key pair. Set the bucket to public-read for bag photos (not sensitive).
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_REGION=nbg1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=brewlog-photos
# Public URL prefix for uploaded photos — used to build the URL stored in Postgres.
NEXT_PUBLIC_S3_PUBLIC_URL_PREFIX=https://brewlog-photos.nbg1.your-objectstorage.com

# ── Session signing ───────────────────────────────────────────────────────────
# 32+ random bytes, base64 or hex — used by src/lib/auth/session.ts to sign JWTs.
AUTH_SECRET=

# ── Cron auth ─────────────────────────────────────────────────────────────────
# Ofelia (docker cron) sends this header to /api/research and /api/coffees/compact.
CRON_SECRET=your-cron-secret

# ── Webhook auth ──────────────────────────────────────────────────────────────
# Used to authenticate POST requests to /api/webhooks/coffee-alert
COFFEE_ALERT_WEBHOOK_SECRET=your-webhook-secret

# ── WebAuthn (Face ID / passkey) ──────────────────────────────────────────────
# Must match the domain the app is served from. Keep these stable across the
# Firebase → Hetzner migration so existing passkeys keep working.
WEBAUTHN_RP_ID=bettertastethansorry.com
WEBAUTHN_ORIGIN=https://bettertastethansorry.com

# ── PIN fallback ──────────────────────────────────────────────────────────────
# Used when WebAuthn fails or during domain moves. 5 attempts then 60s lockout.
AUTH_PIN=your-pin
